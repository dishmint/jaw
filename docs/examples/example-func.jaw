[----------------------------------------------------------------]
[V1] — The first variable
[V2] — The second variable

/FUNC
[V1]: a 1D vector, [V2]: a 1D vector
	[1] — Zip[ [V1], [V2] ]
	[R]: result
	[~] — ([A], [B]) in [1]
		[1] — [R] << [A] + [B]
		[^] append sum to R
	[>] [R]

FUNC {1 2 3} {3 2 1} => {4 4 4}
[^] expected output
