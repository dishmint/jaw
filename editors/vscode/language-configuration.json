{
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(\\[~\\]|\\[&\\]|/\\w+|\\[\\d+\\]\\s*—.*\\?\\s*$)",
    "decreaseIndentPattern": "^\\s*\\[>\\]"
  }
}
