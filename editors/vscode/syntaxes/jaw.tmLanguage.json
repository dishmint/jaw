{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JAW",
  "scopeName": "source.jaw",
  "patterns": [
    { "include": "#code-comment" },
    { "include": "#general-comment" },
    { "include": "#log" },
    { "include": "#return" },
    { "include": "#loop" },
    { "include": "#parallel" },
    { "include": "#complex-cond-true" },
    { "include": "#complex-cond-false" },
    { "include": "#function-definition" },
    { "include": "#variable-access" },
    { "include": "#variable-declaration" },
    { "include": "#inline-assignment-with-value" },
    { "include": "#inline-assignment" },
    { "include": "#step" },
    { "include": "#decorator" },
    { "include": "#variable-reference" }
  ],
  "repository": {
    "code-comment": {
      "name": "comment.line.caret.jaw",
      "begin": "^(\\s*)(\\[\\^\\])",
      "beginCaptures": {
        "2": { "name": "comment.line.caret.jaw" }
      },
      "end": "(?=^\\s*(?:\\[\\d+\\]|\\[\\^\\]|\\[\\*\\]|\\[!\\]|\\[>\\]|\\[~\\]|\\[&\\]|\\[\\+\\]|\\[-\\]|\\[[A-Za-z][A-Za-z0-9_]*\\]\\s*[—:]|/|`{3,}|~{3,}))",
      "patterns": [
        { "include": "#comment-variable-reference" },
        { "include": "#comment-function-reference" }
      ]
    },
    "general-comment": {
      "name": "comment.line.asterisk.jaw",
      "begin": "^(\\s*)(\\[\\*\\])",
      "beginCaptures": {
        "2": { "name": "comment.line.asterisk.jaw" }
      },
      "end": "(?=^\\s*(?:\\[\\d+\\]|\\[\\^\\]|\\[\\*\\]|\\[!\\]|\\[>\\]|\\[~\\]|\\[&\\]|\\[\\+\\]|\\[-\\]|\\[[A-Za-z][A-Za-z0-9_]*\\]\\s*[—:]|/|`{3,}|~{3,}))",
      "patterns": [
        { "include": "#comment-variable-reference" },
        { "include": "#comment-function-reference" }
      ]
    },
    "comment-variable-reference": {
      "match": "\\[[A-Za-z][A-Za-z0-9_]*\\]",
      "name": "variable.other.jaw"
    },
    "comment-function-reference": {
      "match": "/\\w+",
      "name": "entity.name.function.jaw"
    },
    "log": {
      "begin": "^(\\s*)(\\[!\\])(\\s*—\\s*)(?:(\\S.*:)\\s*$|(#\\w+(?::\\S+)?\\s+)?)?(.*)?",
      "beginCaptures": {
        "2": { "name": "keyword.other.log.jaw" },
        "3": { "name": "punctuation.separator.jaw" },
        "4": { "name": "markup.italic.log-title.jaw" },
        "5": { "name": "entity.other.attribute-name.decorator.jaw" },
        "6": {
          "name": "string.unquoted.log.jaw",
          "patterns": [
            { "include": "#variable-reference" },
            { "include": "#access-operator" },
            { "include": "#step-reference" },
            { "include": "#number-literal" }
          ]
        }
      },
      "end": "(?=^\\s*(?:`{3,}|~{3,}))|(?=^(?!\\s*$)(?!\\1\\s+\\S))",
      "contentName": "string.unquoted.log.jaw",
      "patterns": [
        { "include": "#decorator" },
        { "include": "#variable-reference" },
        { "include": "#access-operator" },
        { "include": "#step-reference" },
        { "include": "#number-literal" }
      ]
    },
    "return": {
      "match": "^(\\s*)(\\[>\\])(\\s*)(.*)",
      "captures": {
        "2": { "name": "keyword.control.return.jaw" },
        "4": {
          "patterns": [
            { "include": "#function-reference" },
            { "include": "#decorator" },
            { "include": "#variable-reference" },
            { "include": "#access-operator" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "loop": {
      "match": "^(\\s*)(\\[~\\])(\\s*—\\s*)(.*)",
      "captures": {
        "2": { "name": "keyword.control.loop.jaw" },
        "3": { "name": "punctuation.separator.jaw" },
        "4": {
          "patterns": [
            { "include": "#in-keyword" },
            { "include": "#variable-reference" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "parallel": {
      "name": "keyword.control.parallel.jaw",
      "match": "^\\s*\\[&\\]"
    },
    "complex-cond-true": {
      "match": "^(\\s*)(\\[\\+\\])(\\s*—\\s*)(.*)",
      "captures": {
        "2": { "name": "keyword.control.conditional.true.jaw" },
        "3": { "name": "punctuation.separator.jaw" },
        "4": {
          "patterns": [
            { "include": "#function-reference" },
            { "include": "#variable-reference" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "complex-cond-false": {
      "match": "^(\\s*)(\\[-\\])(\\s*—\\s*)(.*)",
      "captures": {
        "2": { "name": "keyword.control.conditional.false.jaw" },
        "3": { "name": "punctuation.separator.jaw" },
        "4": {
          "patterns": [
            { "include": "#function-reference" },
            { "include": "#variable-reference" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "function-definition": {
      "match": "^(\\s*)(/\\w+)(.*)",
      "captures": {
        "2": { "name": "entity.name.function.jaw" },
        "3": {
          "patterns": [
            { "include": "#decorator" },
            { "include": "#inline-assignment-inline" },
            { "include": "#variable-reference" }
          ]
        }
      }
    },
    "variable-declaration": {
      "match": "^(\\s*)(\\[[A-Za-z][A-Za-z0-9_]*\\])(\\s*—\\s*)(.*)",
      "captures": {
        "2": { "name": "variable.other.definition.jaw" },
        "3": { "name": "punctuation.separator.jaw" },
        "4": {
          "patterns": [
            { "include": "#decorator" },
            { "include": "#variable-reference" },
            { "include": "#step-reference" },
            { "include": "#number-literal" }
          ]
        }
      }
    },
    "inline-assignment-with-value": {
      "match": "(\\[[A-Za-z][A-Za-z0-9_]*\\])(\\s*:\\s*)(.*?)(\\s+=\\s+)(\\S.*?)\\s*$",
      "captures": {
        "1": { "name": "variable.other.jaw" },
        "2": { "name": "punctuation.separator.assignment.jaw" },
        "3": {
          "name": "string.unquoted.description.jaw",
          "patterns": [
            { "include": "#variable-reference" },
            { "include": "#step-reference" }
          ]
        },
        "4": { "name": "keyword.operator.jaw" },
        "5": {
          "name": "constant.other.value.jaw",
          "patterns": [
            { "include": "#function-reference" },
            { "include": "#variable-reference" },
            { "include": "#access-operator" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "inline-assignment": {
      "match": "(\\[[A-Za-z][A-Za-z0-9_]*\\])(\\s*:\\s*)((?:[^,](?!\\s+=\\s))*[^,]?)",
      "captures": {
        "1": { "name": "variable.other.jaw" },
        "2": { "name": "punctuation.separator.assignment.jaw" },
        "3": {
          "name": "string.unquoted.description.jaw",
          "patterns": [
            { "include": "#variable-reference" },
            { "include": "#step-reference" }
          ]
        }
      }
    },
    "inline-assignment-inline": {
      "match": "(\\[[A-Za-z][A-Za-z0-9_]*\\])(\\s*:\\s*)((?:(?!\\s*[,=]).)*?)(?:(\\s*=\\s*)(\\S+))?",
      "captures": {
        "1": { "name": "variable.other.jaw" },
        "2": { "name": "punctuation.separator.assignment.jaw" },
        "3": { "name": "string.unquoted.description.jaw" },
        "4": { "name": "keyword.operator.jaw" },
        "5": {
          "name": "constant.other.value.jaw",
          "patterns": [
            { "include": "#function-reference" },
            { "include": "#variable-reference" },
            { "include": "#access-operator" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "step": {
      "match": "^(\\s*)(\\[)(\\d+)(\\])(\\s*—\\s*)(.*)",
      "captures": {
        "2": { "name": "punctuation.definition.step.jaw" },
        "3": { "name": "constant.numeric.step.jaw" },
        "4": { "name": "punctuation.definition.step.jaw" },
        "5": { "name": "punctuation.separator.step.jaw" },
        "6": {
          "patterns": [
            { "include": "#conditional-operators" },
            { "include": "#inline-assignment-inline" },
            { "include": "#function-reference" },
            { "include": "#decorator" },
            { "include": "#variable-reference" },
            { "include": "#access-operator" },
            { "include": "#in-keyword" },
            { "include": "#step-reference" },
            { "include": "#number-literal" },
            { "include": "#operators" }
          ]
        }
      }
    },
    "variable-reference": {
      "match": "\\[[A-Za-z][A-Za-z0-9_]*\\]",
      "name": "variable.other.jaw"
    },
    "variable-access": {
      "match": "(\\[[A-Za-z][A-Za-z0-9_]*\\])(@)(\\[[A-Za-z][A-Za-z0-9_]*\\])",
      "captures": {
        "1": { "name": "variable.other.jaw" },
        "2": { "name": "keyword.operator.access.jaw" },
        "3": { "name": "variable.other.jaw" }
      }
    },
    "access-operator": {
      "match": "(?<=\\])(@)(?=\\[)",
      "captures": {
        "1": { "name": "keyword.operator.access.jaw" }
      }
    },
    "decorator": {
      "match": "(#)(\\w+)(?:(:)(\\S+))?",
      "captures": {
        "1": { "name": "punctuation.definition.decorator.jaw" },
        "2": { "name": "entity.other.attribute-name.decorator.jaw" },
        "3": { "name": "punctuation.separator.decorator.jaw" },
        "4": { "name": "string.unquoted.decorator.jaw" }
      }
    },
    "function-reference": {
      "match": "/\\w+",
      "name": "entity.name.function.jaw"
    },
    "conditional-operators": {
      "match": "(\\?)|(\\|)",
      "captures": {
        "1": { "name": "keyword.control.conditional.jaw" },
        "2": { "name": "keyword.control.conditional.jaw" }
      }
    },
    "in-keyword": {
      "match": "\\bin\\b",
      "name": "keyword.operator.iterator.jaw"
    },
    "operators": {
      "match": "<<|==|!=|>=|<=|\\+=|-=|\\*=|/=|[+\\-*/><]",
      "name": "keyword.operator.jaw"
    },
    "step-reference": {
      "match": "(\\[)(\\d+)(\\])",
      "captures": {
        "1": { "name": "punctuation.section.step-reference.jaw" },
        "2": { "name": "constant.numeric.step.jaw" },
        "3": { "name": "punctuation.section.step-reference.jaw" }
      }
    },
    "number-literal": {
      "match": "-?\\d+(\\.\\d+)?",
      "name": "constant.numeric.jaw"
    }
  }
}
